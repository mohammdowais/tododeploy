<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="tododeploy.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Todo Studio">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F172A" Offset="0" />
                <GradientStop Color="#111C33" Offset="0.6" />
                <GradientStop Color="#172554" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.Resources>
            <LinearGradientBrush x:Key="HeroGradientBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2B5ED9" Offset="0" />
                <GradientStop Color="#31B6A7" Offset="0.55" />
                <GradientStop Color="#7F56D9" Offset="1" />
            </LinearGradientBrush>
        </Grid.Resources>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="1280" Margin="32" Spacing="24">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="32"
                            MinHeight="320"
                            CornerRadius="28"
                            Background="{StaticResource HeroGradientBrush}">
                        <StackPanel Spacing="18">
                            <Border Padding="12,6"
                                    HorizontalAlignment="Left"
                                    Background="#26FFFFFF"
                                    CornerRadius="999">
                                <TextBlock Text="Windows-style task board"
                                           Foreground="White"
                                           FontSize="13"
                                           FontWeight="SemiBold" />
                            </Border>

                            <TextBlock Text="Plan multiple todo lists in one clean workspace."
                                       Foreground="White"
                                       FontSize="38"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />

                            <TextBlock Text="UI-only concept with gradients, glassy cards, and subtle entrance motion. Releases are published through GitHub and installed builds can check for updates directly from the app."
                                       Foreground="#E8F1FF"
                                       FontSize="15"
                                       TextWrapping="Wrap"
                                       MaxWidth="640" />

                            <Border Padding="22"
                                    Margin="0,10,0,0"
                                    Background="#22FFFFFF"
                                    BorderBrush="#33FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="24">
                                <StackPanel Spacing="14">
                                    <TextBlock Text="Create a list"
                                               Foreground="White"
                                               FontSize="20"
                                               FontWeight="SemiBold" />

                                    <TextBox Header="List title"
                                             PlaceholderText="Product launch checklist"
                                             Text="Product launch checklist"
                                             MinHeight="52" />

                                    <TextBox Header="Add item"
                                             PlaceholderText="Draft hero section copy"
                                             Text="Draft hero section copy"
                                             MinHeight="52" />

                                    <Button Content="Save list"
                                            MinHeight="50"
                                            Padding="24,0"
                                            Foreground="White"
                                            Background="#2563EB" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Padding="24"
                            Background="#1E293B"
                            BorderBrush="#334155"
                            BorderThickness="1"
                            CornerRadius="28">
                        <StackPanel Spacing="18">
                            <TextBlock Text="Overview"
                                       Foreground="White"
                                       FontSize="20"
                                       FontWeight="SemiBold" />

                            <Border Padding="18"
                                    Background="#162032"
                                    CornerRadius="22">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Lists in view"
                                               Foreground="#94A3B8" />
                                    <TextBlock Text="3"
                                               Foreground="White"
                                               FontSize="40"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>

                            <Border Padding="18"
                                    Background="#162032"
                                    CornerRadius="22">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Look"
                                               Foreground="#94A3B8" />
                                    <TextBlock Text="Mica backdrop, gradient hero, rounded cards"
                                               Foreground="White"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Padding="18"
                                    Background="#162032"
                                    CornerRadius="22">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Updates"
                                               Foreground="#94A3B8" />
                                    <Button x:Name="CheckForUpdatesButton"
                                            Click="CheckForUpdatesButton_Click"
                                            Content="Check for updates"
                                            HorizontalAlignment="Left"
                                            MinHeight="44"
                                            Padding="18,0" />
                                    <TextBlock x:Name="UpdateStatusText"
                                               Text="Installed release builds can download updates from GitHub Releases."
                                               Foreground="White"
                                               Opacity="0.82"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Text="Saved lists"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="SemiBold" />

                <Border Padding="24"
                        Background="#1E293B"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        CornerRadius="28">
                    <Border.Transitions>
                        <TransitionCollection>
                            <EntranceThemeTransition FromVerticalOffset="32" IsStaggeringEnabled="True" />
                        </TransitionCollection>
                    </Border.Transitions>

                    <StackPanel Spacing="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Design sprint"
                                           Foreground="White"
                                           FontSize="22"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="3 items"
                                           Foreground="#94A3B8" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                                <Button Content="Edit" />
                                <Button Content="Delete" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     Header="Add item"
                                     PlaceholderText="Add another task to this list"
                                     MinHeight="52" />

                            <Button Grid.Column="1"
                                    VerticalAlignment="Bottom"
                                    Content="Add item" />
                        </Grid>

                        <Border Padding="14"
                                Background="#162032"
                                CornerRadius="20">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Review motion studies"
                                           Foreground="White"
                                           VerticalAlignment="Center" />
                                <ToggleButton Grid.Column="1"
                                              Content="Mark done" />
                                <Button Grid.Column="2"
                                        Content="Delete" />
                            </Grid>
                        </Border>

                        <Border Padding="14"
                                Background="#162032"
                                CornerRadius="20">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Refine hero card spacing"
                                           Foreground="#CBD5E1"
                                           VerticalAlignment="Center" />
                                <ToggleButton Grid.Column="1"
                                              IsChecked="True"
                                              Content="Done" />
                                <Button Grid.Column="2"
                                        Content="Delete" />
                            </Grid>
                        </Border>

                        <Border Padding="14"
                                Background="#162032"
                                CornerRadius="20">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Ship dark mode mockup"
                                           Foreground="White"
                                           VerticalAlignment="Center" />
                                <ToggleButton Grid.Column="1"
                                              Content="Mark done" />
                                <Button Grid.Column="2"
                                        Content="Delete" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Padding="24"
                        Background="#1E293B"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        CornerRadius="28">
                    <Border.Transitions>
                        <TransitionCollection>
                            <EntranceThemeTransition FromVerticalOffset="44" IsStaggeringEnabled="True" />
                        </TransitionCollection>
                    </Border.Transitions>

                    <StackPanel Spacing="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Weekend errands"
                                           Foreground="White"
                                           FontSize="22"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="3 items"
                                           Foreground="#94A3B8" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                                <Button Content="Edit" />
                                <Button Content="Delete" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     Header="Add item"
                                     PlaceholderText="Add another task to this list"
                                     MinHeight="52" />

                            <Button Grid.Column="1"
                                    VerticalAlignment="Bottom"
                                    Content="Add item" />
                        </Grid>

                        <Border Padding="14"
                                Background="#162032"
                                CornerRadius="20">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Pick up groceries"
                                           Foreground="White"
                                           VerticalAlignment="Center" />
                                <ToggleButton Grid.Column="1"
                                              Content="Mark done" />
                                <Button Grid.Column="2"
                                        Content="Delete" />
                            </Grid>
                        </Border>

                        <Border Padding="14"
                                Background="#162032"
                                CornerRadius="20">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Book AC service"
                                           Foreground="White"
                                           VerticalAlignment="Center" />
                                <ToggleButton Grid.Column="1"
                                              Content="Mark done" />
                                <Button Grid.Column="2"
                                        Content="Delete" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
