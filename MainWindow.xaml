<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="tododeploy.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Todo Studio">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F172A" Offset="0" />
                <GradientStop Color="#111C33" Offset="0.6" />
                <GradientStop Color="#172554" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.Resources>
            <LinearGradientBrush x:Key="HeroGradientBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2B5ED9" Offset="0" />
                <GradientStop Color="#31B6A7" Offset="0.55" />
                <GradientStop Color="#7F56D9" Offset="1" />
            </LinearGradientBrush>
        </Grid.Resources>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="1280" Margin="32" Spacing="24">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="32"
                            MinHeight="320"
                            CornerRadius="28"
                            Background="{StaticResource HeroGradientBrush}">
                        <StackPanel Spacing="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Padding="12,6"
                                        HorizontalAlignment="Left"
                                        Background="#26FFFFFF"
                                        CornerRadius="999">
                                    <TextBlock Text="Windows-style task board"
                                               Foreground="White"
                                               FontSize="13"
                                               FontWeight="SemiBold" />
                                </Border>

                                <Button Grid.Column="1"
                                        Margin="12,0,0,0"
                                        Click="MinimizeButton_Click"
                                        Content="Minimize" />
                                <Button Grid.Column="2"
                                        Margin="12,0,0,0"
                                        Click="ExitFullScreenButton_Click"
                                        Content="Exit full screen" />
                            </Grid>

                            <TextBlock Text="Plan multiple todo lists in one clean workspace."
                                       Foreground="White"
                                       FontSize="38"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />

                            <TextBlock Text="Lists and items are stored in SQLite. The app writes action logs for create, save, edit, delete, done-state changes, window actions, and update checks."
                                       Foreground="#E8F1FF"
                                       FontSize="15"
                                       TextWrapping="Wrap"
                                       MaxWidth="640" />

                            <Border Padding="22"
                                    Margin="0,10,0,0"
                                    Background="#22FFFFFF"
                                    BorderBrush="#33FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="24">
                                <StackPanel Spacing="14">
                                    <TextBlock x:Name="ComposerTitleText"
                                               Text="Create a list"
                                               Foreground="White"
                                               FontSize="20"
                                               FontWeight="SemiBold" />

                                    <TextBox x:Name="ListTitleTextBox"
                                             Header="List title"
                                             PlaceholderText="Product launch checklist"
                                             MinHeight="52" />

                                    <TextBox x:Name="FirstItemTextBox"
                                             Header="First item"
                                             PlaceholderText="Draft hero section copy"
                                             MinHeight="52" />

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Button x:Name="SaveListButton"
                                                Click="SaveListButton_Click"
                                                Content="Save list"
                                                MinHeight="50"
                                                Padding="24,0"
                                                Foreground="White"
                                                Background="#2563EB" />

                                        <Button x:Name="CancelEditButton"
                                                Grid.Column="1"
                                                Click="CancelEditButton_Click"
                                                Content="Cancel"
                                                MinHeight="50"
                                                Padding="18,0"
                                                Visibility="Collapsed" />

                                        <TextBlock Grid.Column="2"
                                                   VerticalAlignment="Center"
                                                   Text="Use Edit on a saved list to rename it and optionally add another first item in the same action."
                                                   Foreground="#E5F0FF"
                                                   TextWrapping="Wrap" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Padding="24"
                            Background="#1E293B"
                            BorderBrush="#334155"
                            BorderThickness="1"
                            CornerRadius="28">
                        <StackPanel Spacing="18">
                            <TextBlock Text="Overview"
                                       Foreground="White"
                                       FontSize="20"
                                       FontWeight="SemiBold" />

                            <Border Padding="18"
                                    Background="#162032"
                                    CornerRadius="22">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Lists in view"
                                               Foreground="#94A3B8" />
                                    <TextBlock x:Name="ListCountText"
                                               Text="Loading..."
                                               Foreground="White"
                                               FontSize="40"
                                               FontWeight="SemiBold" />
                                    <ProgressRing x:Name="ListsLoadingRing"
                                                  IsActive="True"
                                                  Width="28"
                                                  Height="28"
                                                  HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border Padding="18"
                                    Background="#162032"
                                    CornerRadius="22">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Storage"
                                               Foreground="#94A3B8" />
                                    <TextBlock x:Name="DbPathText"
                                               Foreground="White"
                                               TextWrapping="Wrap" />
                                    <TextBlock x:Name="LogPathText"
                                               Foreground="White"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Padding="18"
                                    Background="#162032"
                                    CornerRadius="22">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Updates"
                                               Foreground="#94A3B8" />
                                    <Button x:Name="CheckForUpdatesButton"
                                            Click="CheckForUpdatesButton_Click"
                                            Content="Check for updates"
                                            HorizontalAlignment="Left"
                                            MinHeight="44"
                                            Padding="18,0" />
                                    <TextBlock x:Name="UpdateStatusText"
                                               Text="Installed release builds can download updates from GitHub Releases."
                                               Foreground="White"
                                               Opacity="0.82"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Text="Saved lists"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="SemiBold" />

                <TextBlock x:Name="ListsLoadingText"
                           Text="Loading lists from database..."
                           Foreground="#CBD5E1"
                           Visibility="Visible" />

                <StackPanel x:Name="ListsHost" Spacing="20" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
